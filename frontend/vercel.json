{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "regions": [
    "fra1"
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.lksgcompass.de/:path*"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "https://api.lksgcompass.de",
    "BACKEND_URL": "https://api.lksgcompass.de"
  }
}